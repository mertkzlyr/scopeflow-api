PROJECT_NAME=ScopeFlow API
ENVIRONMENT=development

JWT_SECRET_KEY=change-this-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

POSTGRES_USER=scopeflow_user
POSTGRES_PASSWORD=scopeflow_password
POSTGRES_DB=scopeflow_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg://scopeflow_user:scopeflow_password@localhost:5432/scopeflow_db